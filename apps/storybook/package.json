{
  "name": "@aurora-ui/storybook-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "pnpm run typecheck",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "storybook": "storybook dev -p 6006",
    "storybook:smoke": "storybook dev -p 6006 --smoke-test --ci",
    "build-storybook": "storybook build && node ../../scripts/normalize-storybook-static-metadata.mjs",
    "storybook:test": "test-storybook --url http://127.0.0.1:6106 --maxWorkers=2",
    "storybook:test:ci": "sh -c 'fuser -k 6106/tcp >/dev/null 2>&1 || true; start-server-and-test \"node ../../scripts/serve-storybook-static.mjs\" http-get://127.0.0.1:6106 \"pnpm storybook:test\"'",
    "chromatic": "chromatic --exit-once-uploaded --storybook-build-dir storybook-static"
  },
  "dependencies": {
    "@aurora-ui/react": "workspace:*",
    "@aurora-ui/tokens": "workspace:*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@storybook/test": "8.6.18",
    "@storybook/test-runner": "^0.20.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "axe-playwright": "^2.2.2",
    "chromatic": "^11.29.0",
    "http-server": "^14.1.1",
    "start-server-and-test": "^2.1.5",
    "storybook": "8.6.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.14"
  }
}
