{
  "name": "react-ui-library-workspace",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaocao12306/UI.git"
  },
  "homepage": "https://github.com/xiaocao12306/UI",
  "bugs": {
    "url": "https://github.com/xiaocao12306/UI/issues"
  },
  "packageManager": "pnpm@10.8.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "demo:dev": "pnpm --filter @aurora-ui/demo dev",
    "demo:build": "pnpm --filter @aurora-ui/demo build",
    "demo:preview": "pnpm --filter @aurora-ui/demo preview",
    "demo:e2e": "playwright test",
    "demo:e2e:grep": "playwright test -g",
    "demo:dist:check": "node scripts/check-demo-dist-freshness.mjs",
    "storybook:dev": "pnpm --filter @aurora-ui/storybook-app storybook",
    "storybook:smoke": "pnpm --filter @aurora-ui/storybook-app storybook:smoke",
    "storybook:build": "pnpm --filter @aurora-ui/storybook-app build-storybook",
    "storybook:test": "pnpm --filter @aurora-ui/storybook-app storybook:test",
    "storybook:test:grep": "node scripts/run-storybook-test-grep.mjs",
    "storybook:docs:check": "node scripts/check-storybook-docs-imports.mjs",
    "storybook:docs:parity:check": "node scripts/check-storybook-docs-parity.mjs",
    "storybook:docs:structure:check": "node scripts/check-storybook-docs-structure.mjs",
    "docs:commands:check": "node scripts/check-doc-command-parity.mjs",
    "storybook:play:check": "node scripts/check-story-play-coverage.mjs",
    "storybook:coverage:report": "node scripts/storybook-coverage-report.mjs",
    "storybook:coverage:check": "pnpm storybook:coverage:report -- --strict",
    "storybook:static:check": "node scripts/check-storybook-static-freshness.mjs",
    "storybook:a11y:skip-check": "node scripts/check-storybook-a11y-skip-list.mjs",
    "storybook:test:ci": "pnpm storybook:coverage:check && pnpm storybook:docs:check && pnpm storybook:docs:parity:check && pnpm storybook:docs:structure:check && pnpm docs:commands:check && pnpm storybook:play:check && pnpm storybook:static:check && pnpm storybook:a11y:skip-check && pnpm --filter @aurora-ui/storybook-app storybook:test:ci",
    "chromatic": "pnpm --filter @aurora-ui/storybook-app chromatic",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "test:coverage": "pnpm exec vitest run --coverage packages/primitives/src packages/react/src packages/tokens/src",
    "coverage:gate": "pnpm test:coverage",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "changeset": "changeset",
    "changeset:required": "node scripts/check-changeset-required.mjs --base origin/main",
    "release:exports:check": "node scripts/check-package-exports.mjs",
    "version-packages": "changeset version",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:preflight:chromatic": "node scripts/release-preflight.mjs --scope=chromatic",
    "release:preflight:publish": "node scripts/release-preflight.mjs --scope=publish",
    "release:dry-run": "node scripts/release-dry-run.mjs",
    "release:gate:ci": "pnpm verify && pnpm release:exports:check && pnpm coverage:gate && pnpm demo:e2e && pnpm demo:dist:check && pnpm storybook:test:ci",
    "release:gate": "pnpm release:gate:ci && pnpm release:dry-run",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@changesets/cli": "^2.29.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.18.6",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.22.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^24.1.3",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2",
    "tsup": "^8.4.0",
    "vitest": "^2.1.8"
  }
}
